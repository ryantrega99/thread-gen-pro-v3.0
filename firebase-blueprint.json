{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User account information and access status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "threads": {
      "title": "Generated Thread",
      "description": "A thread generated by the user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "topic": { "type": "string", "description": "Topic of the thread" },
        "thread": { "type": "array", "items": { "type": "string" }, "description": "Array of tweets" },
        "tone": { "type": "string", "description": "Tone used" },
        "booster": { "type": "object", "description": "Viral booster info" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "topic", "thread", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile document"
    },
    "/threads/{threadId}": {
      "schema": "threads",
      "description": "Generated thread document"
    }
  }
}
